<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for all development IPs -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Emulator -->
        <domain includeSubdomains="true">10.0.2.2</domain>

        <!-- Real Device - Specific IPs -->
        <domain includeSubdomains="true">10.0.3.238</domain>

        <!-- Localhost -->
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>

        <!-- Private networks - Common WiFi ranges -->
        <domain includeSubdomains="true">192.168.1.1</domain>
        <domain includeSubdomains="true">192.168.0.1</domain>
        <domain includeSubdomains="true">192.168.220.1</domain>
        <domain includeSubdomains="true">192.168.225.1</domain>

        <!-- Wildcard ranges for development -->
        <domain includeSubdomains="true">10.0.0.1</domain>
        <domain includeSubdomains="true">172.16.0.1</domain>
    </domain-config>

    <!-- Allow all cleartext for debug (use only in development) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
